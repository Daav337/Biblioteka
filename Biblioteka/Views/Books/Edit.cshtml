@model Biblioteka.Models.Book

@{
    ViewData["Title"] = "Edytuj książkę";
    var selectedGenreIds = ViewBag.SelectedGenreIds as List<int> ?? new List<int>();
}

<h1>Edytuj książkę</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <input type="hidden" asp-for="Id" />

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ISBN" class="form-label"></label>
                <input asp-for="ISBN" class="form-control" />
            </div>

            <div class="mb-3">
                <label asp-for="PublishedYear" class="form-label"></label>
                <input asp-for="PublishedYear" class="form-control" type="number"
                       min="1000" max="2100" />
                <span asp-validation-for="PublishedYear" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="AuthorId" class="form-label"></label>
                <select asp-for="AuthorId" class="form-select" asp-items="ViewBag.AuthorList">
                    <option value="">-- Wybierz autora --</option>
                </select>
                <span asp-validation-for="AuthorId" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label class="form-label">Gatunki</label>
                <div class="border rounded p-3">
                    @foreach (var genre in (List<Biblioteka.Models.Genre>)ViewBag.AllGenres)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                   name="selectedGenres" value="@genre.Id"
                                   id="genre_@genre.Id"
                                   @(selectedGenreIds.Contains(genre.Id) ? "checked" : "") />
                            <label class="form-check-label" for="genre_@genre.Id">
                                @genre.Name
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Zapisz zmiany" class="btn btn-primary" />
                <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
            </div>
        </form>
    </div>
</div>