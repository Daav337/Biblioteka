@model Biblioteka.Models.Book

@{
    ViewData["Title"] = "Dodaj książkę";
}

<h1>Dodaj nową książkę</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Title" class="form-label"></label>
                <input asp-for="Title" class="form-control" placeholder="Tytuł książki" />
                <span asp-validation-for="Title" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ISBN" class="form-label"></label>
                <input asp-for="ISBN" class="form-control" placeholder="978-..." />
                <span asp-validation-for="ISBN" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="PublishedYear" class="form-label"></label>
                <input asp-for="PublishedYear" class="form-control" type="number"
                       min="1000" max="2100" placeholder="np. 2023" />
                <span asp-validation-for="PublishedYear" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="AuthorId" class="form-label"></label>
                <select asp-for="AuthorId" class="form-select" asp-items="ViewBag.AuthorList">
                    <option value="">-- Wybierz autora --</option>
                </select>
                <span asp-validation-for="AuthorId" class="text-danger small"></span>
                <div class="form-text">
                    Nie ma autora na liście? 
                    <a asp-controller="Authors" asp-action="Create" target="_blank">
                        Dodaj autora
                    </a>
                </div>
            </div>

            <div class="mb-4">
                <label class="form-label">Gatunki</label>
                <div class="border rounded p-3">
                    @foreach (var genre in (List<Biblioteka.Models.Genre>)ViewBag.AllGenres)
                    {
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox"
                                   name="selectedGenres" value="@genre.Id"
                                   id="genre_@genre.Id" />
                            <label class="form-check-label" for="genre_@genre.Id">
                                @genre.Name
                            </label>
                        </div>
                    }
                </div>
                <div class="form-text">Możesz wybrać wiele gatunków.</div>
            </div>

            <div class="d-flex gap-2">
                <input type="submit" value="Dodaj książkę" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
            </div>
        </form>
    </div>
</div>