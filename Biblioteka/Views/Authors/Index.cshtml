@model IEnumerable<Biblioteka.Models.Author>

@{
    ViewData["Title"] = "Autorzy";
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show">
        @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<h1>Autorzy</h1>
<hr />

<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" asp-action="Index" class="d-flex gap-2">
            <input type="text" name="searchName" value="@ViewBag.SearchName"
                   class="form-control" placeholder="Szukaj po nazwisku lub imieniu..." />
            <button type="submit" class="btn btn-primary">Szukaj</button>
            @if (!string.IsNullOrWhiteSpace(ViewBag.SearchName as string))
            {
                <a asp-action="Index" class="btn btn-outline-secondary">Wyczyść</a>
            }
        </form>
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-success">+ Dodaj autora</a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-info">Brak autorów spełniających kryteria.</div>
}
else
{
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Nazwisko i imię</th>
                <th>Biografia</th>
                <th>Liczba książek</th>
                <th class="text-end">Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var author in Model)
            {
                <tr>
                    <td><strong>@author.FullName</strong></td>
                    <td>
                        @if (!string.IsNullOrEmpty(author.Bio))
                        {
                            @(author.Bio.Length > 80
                                ? author.Bio.Substring(0, 80) + "..."
                                : author.Bio)
                        }
                        else
                        {
                            <span class="text-muted">–</span>
                        }
                    </td>
                    <td>
                        <span class="badge bg-primary">@author.Books.Count</span>
                    </td>
                    <td class="text-end">
                        <a asp-action="Details" asp-route-id="@author.Id"
                           class="btn btn-sm btn-info">Szczegóły</a>
                        <a asp-action="Edit" asp-route-id="@author.Id"
                           class="btn btn-sm btn-warning">Edytuj</a>
                        <a asp-action="Delete" asp-route-id="@author.Id"
                           class="btn btn-sm btn-danger">Usuń</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}