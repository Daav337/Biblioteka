@model Biblioteka.Models.Genre

@{
    ViewData["Title"] = "Usuń gatunek";
}

<h1>Usuń gatunek</h1>
<hr />

<div class="alert alert-danger">
    <h5>⚠️ Czy na pewno chcesz usunąć gatunek <strong>@Model.Name</strong>?</h5>
</div>

<dl class="row">
    <dt class="col-sm-3">Nazwa</dt>
    <dd class="col-sm-9">@Model.Name</dd>

    <dt class="col-sm-3">Liczba książek</dt>
    <dd class="col-sm-9">@Model.Books.Count</dd>
</dl>

@if (Model.Books.Any())
{
    <div class="alert alert-warning">
        Nie można usunąć tego gatunku – jest przypisany do @Model.Books.Count książki/książek.
    </div>
    <a asp-action="Index" class="btn btn-secondary">Powrót</a>
}
else
{
    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2">
            <input type="submit" value="Tak, usuń" class="btn btn-danger" />
            <a asp-action="Index" class="btn btn-secondary">Anuluj</a>
        </div>
    </form>
}